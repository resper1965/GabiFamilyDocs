# =============================================================================
# CONFIGURAÇÕES DO BANCO DE DADOS (SERVIÇOS EXISTENTES NA VPS)
# =============================================================================
# Use as credenciais dos serviços já existentes na VPS
DATABASE_URL=postgresql://postgres:SENHA_POSTGRES@localhost:5432/gabifamilydocs
REDIS_URL=redis://:SENHA_REDIS@localhost:6379

# =============================================================================
# CONFIGURAÇÕES DO BACKEND
# =============================================================================
SECRET_KEY=sua-chave-secreta-super-longa-e-aleatoria-64-caracteres
ENVIRONMENT=production
LOG_LEVEL=INFO

# =============================================================================
# CONFIGURAÇÕES DO KEYCLOAK (JÁ RODANDO NA VPS)
# =============================================================================
# Use a URL do Keycloak já configurado na VPS
KEYCLOAK_URL=https://seu-dominio.com/auth
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=sua-senha-keycloak

# =============================================================================
# CONFIGURAÇÕES DO PAPERLESS NG (JÁ RODANDO NA VPS)
# =============================================================================
# Use a URL do Paperless já configurado na VPS
PAPERLESS_URL=https://seu-dominio.com/paperless
PAPERLESS_ADMIN_USER=admin
PAPERLESS_ADMIN_PASSWORD=sua-senha-paperless
PAPERLESS_SECRET_KEY=sua-chave-paperless-super-longa-e-aleatoria

# =============================================================================
# CONFIGURAÇÕES DO FRONTEND
# =============================================================================
REACT_APP_API_URL=https://seu-dominio.com/api
REACT_APP_KEYCLOAK_URL=https://seu-dominio.com/auth

# =============================================================================
# CONFIGURAÇÕES DO OLLAMA (JÁ RODANDO NA VPS)
# =============================================================================
# Use a URL do Ollama já configurado na VPS
OLLAMA_URL=http://localhost:11434

# =============================================================================
# CONFIGURAÇÕES DO DOMÍNIO
# =============================================================================
DOMAIN_NAME=seu-dominio.com

# =============================================================================
# CONFIGURAÇÕES AVANÇADAS
# =============================================================================
DATABASE_TIMEOUT=30
CACHE_TTL=3600
MAX_FILE_SIZE=10485760
SESSION_TIMEOUT=3600
LOG_FORMAT=json
CORS_ORIGINS=https://seu-dominio.com,https://www.seu-dominio.com
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=900
HEALTH_CHECK_ENDPOINT=/health
METRICS_ENDPOINT=/metrics

# =============================================================================
# CONFIGURAÇÕES DE EMAIL (OPCIONAL)
# =============================================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu-email@gmail.com
# SMTP_PASSWORD=sua-senha-app
# SMTP_TLS=true

# =============================================================================
# CONFIGURAÇÕES DE BACKUP (OPCIONAL)
# =============================================================================
# BACKUP_ENABLED=true
# BACKUP_RETENTION_DAYS=30
# BACKUP_SCHEDULE=0 2 * * * 