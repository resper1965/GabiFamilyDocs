# Database
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/gabifamilydocs

# Security
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Keycloak
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=gabifamilydocs
KEYCLOAK_CLIENT_ID=gabifamilydocs-client
KEYCLOAK_CLIENT_SECRET=gabifamilydocs-secret
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Paperless NG
PAPERLESS_URL=http://paperless-ng:8000
PAPERLESS_USERNAME=admin
PAPERLESS_PASSWORD=admin

# Ollama
OLLAMA_URL=http://ollama:11434

# Frontend
REACT_APP_API_URL=http://localhost:8002
REACT_APP_KEYCLOAK_URL=http://localhost:8080
